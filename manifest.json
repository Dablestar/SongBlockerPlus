{
  "manifest_version": 3,
  "name": "PenisSongBlocker",
  "description": "Block Disgusting Songs",
  "version": "1.0",
  "action": {
    "default_popup": "index.html",
    "default_icon": "./src/icon.png"
  },
  "permissions": ["tabs", "activeTab", "scripting", "nativeMessaging", "storage", "webRequest", "webRequest"],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "content_scripts": [
   {
     "matches": ["https://*.youtube.com/*"],
     "js": ["js/content.js"],
     "run_at": "document_start"
   }
  ],
  "web_accessible_resources": [
  {
    "resources": ["js/injected.js"],
    "matches": ["https://*.youtube.com/*"]
  }
]
}